# Optional environment overrides for claude-tts. Copy to .env and uncomment as
# needed. None of these are required, and none are secrets.

# Interpreter that has mlx-audio installed — ONLY for voice.engine="kokoro".
# It runs daemon/kokoro_worker.py (Apple-Silicon MLX). If unset, the daemon
# falls back to a python3 on PATH, then its own interpreter.
# MLX_PYTHON=/path/to/mlx-audio-env/bin/python

# Override the generated macOS launchd service label (default below).
# CLAUDE_TTS_LAUNCHD_LABEL=com.claude-tts.daemon

# Ollama endpoint for the default local LLM provider (default below).
# OLLAMA_HOST=http://127.0.0.1:11434

# --- Voice tuning (optional; override the matching config.json voice settings) ---
# Kokoro model + voice (engine=kokoro).
# KOKORO_MODEL=mlx-community/Kokoro-82M-bf16
# KOKORO_VOICE=af_heart
# Speech shaping.
# CLAUDE_TTS_RATE=1.0
# CLAUDE_TTS_PITCH=1.0
# CLAUDE_TTS_VOICE_STYLE=default

# Note: CLAUDE_SESSION_ID is injected by Claude Code at runtime — not user-set.
